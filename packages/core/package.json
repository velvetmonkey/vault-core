{
  "name": "@velvetmonkey/vault-core",
  "version": "2.1.2",
  "description": "Shared vault utilities for Flywheel ecosystem (entity scanning, wikilinks, protected zones)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velvetmonkey/flywheel-memory.git",
    "directory": "packages/core"
  },
  "author": "Velvet Monkey <9402464+velvetmonkey@users.noreply.github.com>",
  "keywords": [
    "obsidian",
    "wikilinks",
    "vault",
    "markdown",
    "entities"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/e2e/",
    "test:ci": "vitest run --reporter=github-actions",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "esbuild": "0.27.4",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-frontmatter": "^2.0.0",
    "mdast-util-gfm": "^3.0.0",
    "mdast-util-math": "^3.0.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "micromark-extension-math": "^3.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "data",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
